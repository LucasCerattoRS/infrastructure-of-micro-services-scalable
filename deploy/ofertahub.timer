[Unit]
Description=OfertaHub — Gatilho de 30 em 30 minutos
Requires=ofertahub.service

[Timer]
# Primeira execução: 2 minutos após o boot/login (evita corrida com a rede)
OnBootSec=2min

# Execuções subsequentes: a cada 30 minutos a partir do início anterior
OnUnitActiveSec=30min

# Garante disparo imediato caso um ciclo tenha sido perdido (ex: PC desligado)
Persistent=true

Unit=ofertahub.service

[Install]
WantedBy=timers.target
